{
  "projectName": "demo",
  "needAutoUpgrade": true,
  "iterations": 3,
  "intervalSeconds": 30,
  "appendIterationContext": true,
  "systemPromptFile": "prompts/sys-prompt.md",
  "userPromptFile": "prompts/user-prompt.md",
  "llmAccess": {
    "url": "",
    "apiKey": "",
    "model": ""
  },
  "multiAgent": {
    "enabled": true,
    "maxContextChars": 2800,
    "agents": [
      {
        "name": "innovation_analyst",
        "role": "Innovation Analyst",
        "goal": "澄清需求并产出可直接执行的实现方案。",
        "canEditCode": false,
        "systemPromptFile": "prompts/roles/architect.zh.md"
      },
      {
        "name": "implementation_engineer",
        "role": "Implementation Engineer",
        "goal": "以最小且可上线的代码改动实现方案。",
        "canEditCode": true,
        "systemPromptFile": "prompts/roles/engineer.zh.md"
      },
      {
        "name": "verification_repair_engineer",
        "role": "Verification & Repair Engineer",
        "goal": "验证结果并修复缺陷，直至满足需求。",
        "canEditCode": true,
        "systemPromptFile": "prompts/roles/qa_engineer.zh.md"
      }
    ]
  },
  "codex": {
    "command": "codex",
    "model": "gpt-5.3-codex-xhigh",
    "profile": "",
    "dangerouslyBypassApprovalsAndSandbox": true,
    "timeoutSeconds": 1800,
    "retries": 3,
    "extraArgs": [
      "-c",
      "model_reasoning_effort=\"xhigh\""
    ],
    "dryRun": false,
    "autoGitInit": false,
    "autoGitCommit": true,
    "autoGitPush": true,
    "gitRemote": "origin",
    "gitBranch": "main",
    "gitCommitPrefix": ""
  }
}
